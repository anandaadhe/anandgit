# Copy this file to terraform.tfvars and adjust as needed.

aws_region        = "us-east-1"
availability_zone  = "us-east-1a"
project_name       = "free-tier-demo"

instance_type      = "t2.micro"   # free-tier eligible
create_private_instance = false   # keep false unless you also add a NAT Gateway (extra cost)

# Restrict SSH to your own IP, e.g. "203.0.113.42/32"
# Find yours with: curl -s https://checkip.amazonaws.com
my_ip_cidr = "203.0.113.42/32"

# Optional: name of an EXISTING key pair in this AWS account/region for SSH.
# ssh_key_name = "my-existing-keypair"

# Optional: pick your own globally-unique S3 bucket name.
# bucket_name = "my-unique-static-site-bucket-name"
